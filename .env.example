# ConvertHub API Configuration
# Copy this file to .env and update with your actual API credentials

# API Base URL
API_BASE_URL=https://api.converthub.com/v2

# Your API Key (get it from https://converthub.com/dashboard)
API_KEY="your_api_key_here"

# Optional: Webhook URL for receiving conversion status updates
# WEBHOOK_URL=https://your-domain.com/webhook/converthub

# Optional: Webhook server port (for local testing)
WEBHOOK_PORT=3000

# Optional: Debug mode (true/false)
DEBUG=false

# Optional: Auto-download converted files in webhook handler (true/false)
AUTO_DOWNLOAD=false
